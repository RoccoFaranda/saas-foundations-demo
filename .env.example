# Database
# Local dev: required. Prod: set in Vercel envs.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_foundations_dev?schema=public

# Token Hashing
# Required in all environments (set in .env.local for dev, Vercel for prod).
# Generate a secure random secret for token hashing (e.g., `openssl rand -hex 32`)
TOKEN_HASH_SECRET=

# App URL
# Required locally and in production (set in .env.local for dev, Vercel for prod).
# Preview deployments can fall back to VERCEL_URL when NEXT_PUBLIC_APP_URL is unset.
# Public base URL for building verification links (e.g., http://localhost:3000)
NEXT_PUBLIC_APP_URL=
# Optional: search engine ownership verification tokens (for metadata verification tags).
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
# Optional: IndexNow key used for URL push notifications (mainly Bing/Yandex).
INDEXNOW_KEY=
# Optional: override key file URL if you serve the key at a non-default location.
# If unset, defaults to /indexnow-key on NEXT_PUBLIC_APP_URL.
INDEXNOW_KEY_LOCATION=
# Optional in development, required in deployed preview/production environments for protected readiness checks.
# Used by GET /api/ready via Authorization: Bearer <READINESS_SECRET>.
READINESS_SECRET=

# Auth.js
# Required in all environments (set in .env.local for dev, Vercel for prod).
# Generate a secure random secret for Auth.js (e.g., `openssl rand -base64 32`)
AUTH_SECRET=

# Consent audit replay signing
# Required when using signed consent replay tokens.
# Generate a secure random secret (e.g., `openssl rand -hex 32`)
CONSENT_AUDIT_SIGNING_SECRET=

# Upstash Redis (rate limiting)
# Optional for local dev (in-memory fallback). In production, missing envs fail closed unless fallback is enabled.
# Preview deployments can omit these, but rate-limit behavior will differ from production.
# Vercel's Upstash integration may inject KV_REST_API_URL and KV_REST_API_TOKEN instead; the app accepts either pair.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: allow in-memory fallback in production (weaker across instances). Default is false.
ALLOW_IN_MEMORY_RATE_LIMIT_FALLBACK=false

# Account deletion lifecycle
# Optional override: grace period in days before final purge. Default is 14.
ACCOUNT_DELETION_GRACE_DAYS=14
# Optional override: max users purged per cron run. Default is 100.
ACCOUNT_DELETION_PURGE_BATCH_SIZE=100
# Required in production if using the purge cron route.
CRON_SECRET=

# Cloudflare Turnstile (bot protection)
# Optional for local dev (use official Cloudflare test keys). Required in production when bot protection is enabled.
# Preview deployments can use official test keys or leave both unset.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional override: allow signups without Turnstile protection. Default is false.
TURNSTILE_ALLOW_BYPASS=false

# Email Provider (Resend)
# Get your API key from https://resend.com/api-keys
# Recommended: use a dedicated transactional sender subdomain (example: mail.yourdomain.com)
# with SPF, DKIM, and DMARC configured before enabling production sends.
RESEND_API_KEY=
# Recommended format: Display Name <address@domain>
EMAIL_FROM=SaaS Foundations Demo <notifications@mail.saasfoundationsdemo.com>
# Optional explicit reply-to; when unset, SUPPORT_EMAIL is used when valid.
EMAIL_REPLY_TO=support@saasfoundationsdemo.com
# Support contact used in runtime/not-found error pages.
# Required in production.
SUPPORT_EMAIL=support@saasfoundationsdemo.com
# Public profile + legal metadata
# Required in production.
PUBLIC_CONTACT_EMAIL=hello@saasfoundationsdemo.com
LEGAL_CONTACT_EMAIL=legal@saasfoundationsdemo.com
LEGAL_CONTROLLER_NAME=
# Optional in all environments. Leave blank when not applicable.
LEGAL_CONTACT_ADDRESS=
LEGAL_DPO_CONTACT=
# Optional override values:
# - resend
# - dev-mailbox
# - resend+dev-mailbox (send real email and append to dev mailbox)
# If blank, defaults are: test -> in-memory test adapter, development -> dev-mailbox, production -> resend.
EMAIL_PROVIDER=
# Required only when NODE_ENV=production and EMAIL_PROVIDER includes dev-mailbox.
ALLOW_DEV_MAILBOX_IN_PROD=false

# Cookie consent demo toggle
# Optional: enables a demo non-essential analytics service so the consent banner appears.
NEXT_PUBLIC_CONSENT_DEMO_ANALYTICS=false

# Dev mailbox
# Optional: custom path for the dev mailbox JSON file (used by local debugging and E2E wiring).
DEV_MAILBOX_PATH=

# Error-page test route
# Optional: enables /dev/force-error for deterministic E2E runtime error coverage.
# Production safety: route only enables in production when BOTH flags are true.
# Recommended: keep ALLOW_ERROR_TEST_ROUTE_IN_PROD=false outside test environments.
ENABLE_ERROR_TEST_ROUTE=false
ALLOW_ERROR_TEST_ROUTE_IN_PROD=false
