# Database
# Local dev: required. Prod: set in Vercel envs.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_foundations_dev?schema=public

# Token Hashing
# Required in all environments (set in .env.local for dev, Vercel for prod).
# Generate a secure random secret for token hashing (e.g., `openssl rand -hex 32`)
TOKEN_HASH_SECRET=

# App URL
# Required in all environments (set in .env.local for dev, Vercel for prod).
# Public base URL for building verification links (e.g., http://localhost:3000)
NEXT_PUBLIC_APP_URL=

# Auth.js
# Required in all environments (set in .env.local for dev, Vercel for prod).
# Generate a secure random secret for Auth.js (e.g., `openssl rand -base64 32`)
AUTH_SECRET=

# Consent audit replay signing
# Required when using signed consent replay tokens.
# Generate a secure random secret (e.g., `openssl rand -hex 32`)
CONSENT_AUDIT_SIGNING_SECRET=

# Upstash Redis (rate limiting)
# Optional for local dev (in-memory fallback). In production, missing envs fail closed unless fallback is enabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: allow in-memory fallback in production (weaker across instances). Default is false.
ALLOW_IN_MEMORY_RATE_LIMIT_FALLBACK=false

# Account deletion lifecycle
# Optional override: grace period in days before final purge. Default is 14.
ACCOUNT_DELETION_GRACE_DAYS=14
# Optional override: max users purged per cron run. Default is 100.
ACCOUNT_DELETION_PURGE_BATCH_SIZE=100
# Required in production if using the purge cron route.
ACCOUNT_DELETION_CRON_SECRET=

# Cloudflare Turnstile (bot protection)
# Optional for local dev (use official Cloudflare test keys). Required in prod when bot protection is enabled.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional override: allow signups without Turnstile protection. Default is false.
TURNSTILE_ALLOW_BYPASS=false

# Email Provider (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
# Optional override values:
# - resend
# - dev-mailbox
# - resend+dev-mailbox (send real email and append to dev mailbox)
# If blank, defaults are: test -> in-memory test adapter, development -> dev-mailbox, production -> resend.
EMAIL_PROVIDER=
# Required only when NODE_ENV=production and EMAIL_PROVIDER includes dev-mailbox.
ALLOW_DEV_MAILBOX_IN_PROD=false

# Cookie consent demo toggle
# Optional: enables a demo non-essential analytics service so the consent banner appears.
NEXT_PUBLIC_CONSENT_DEMO_ANALYTICS=false

# Dev mailbox
# Optional: custom path for the dev mailbox JSON file (used by local debugging and E2E wiring).
DEV_MAILBOX_PATH=
